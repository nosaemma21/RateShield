# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# Render provides PORT automatically.
# In Docker/Render, app startup should map this to ASPNETCORE_URLS later if needed.
PORT=8080

# RateShield storage
RateShield__Storage__Mode=InMemory
RateShield__Storage__FailureBehavior=FailClosed

# RateShield identity
RateShield__Identity__Strategy=HeaderThenIp
RateShield__Identity__ApiKeyHeaderName=X-Api-Key
RateShield__Identity__ClientIdHeaderName=X-Client-Id
RateShield__Identity__TrustForwardedHeaders=false
RateShield__Identity__ForwardedForHeaderName=X-Forwarded-For

# Default policy
RateShield__Policies__Default__Capacity=100
RateShield__Policies__Default__RefillTokens=10
RateShield__Policies__Default__RefillPeriodSeconds=1
RateShield__Policies__Default__RequestCost=1

# Route policy mapping
RateShield__Routes__sample-api__PolicyName=Default

# YARP backend destination
ReverseProxy__Clusters__sample-backend__Destinations__sample-backend-primary__Address=https://replace-with-production-backend.example.com/