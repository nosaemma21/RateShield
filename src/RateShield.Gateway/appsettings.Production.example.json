{
  "RateShield": {
    "Storage": {
      "Mode": "InMemory",
      "FailureBehavior": "FailClosed"
    },
    "Identity": {
      "Strategy": "HeaderThenIp",
      "ApiKeyHeaderName": "X-Api-Key",
      "ClientIdHeaderName": "X-Client-Id",
      "TrustForwardedHeaders": false,
      "ForwardedForHeaderName": "X-Forwarded-For"
    },
    "Cleanup": {
      "IntervalSeconds": 60,
      "BucketIdleTimeoutSeconds": 900,
      "MaxBucketsPerScan": 10000
    },
    "Policies": {
      "Default": {
        "Capacity": 100,
        "RefillTokens": 10,
        "RefillPeriodSeconds": 1,
        "RequestCost": 1
      },
      "Strict": {
        "Capacity": 20,
        "RefillTokens": 2,
        "RefillPeriodSeconds": 1,
        "RequestCost": 1
      }
    },
    "Routes": {
      "sample-api": {
        "PolicyName": "Default"
      }
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "sample-backend": {
        "Destinations": {
          "sample-backend-primary": {
            "Address": "https://replace-with-production-backend.example.com/"
          }
        }
      }
    }
  }
}