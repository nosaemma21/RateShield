{
  "RateShield": {
    "Storage": {
      "Mode": "InMemory",
      "FailureBehavior": "FailClosed"
    },
    "Identity": {
      "Strategy": "HeaderThenIp",
      "ApiKeyHeaderName": "X-Api-Key",
      "ClientIdHeaderName": "X-Client-Id",
      "TrustForwardedHeaders": false,
      "ForwardedForHeaderName": "X-Forwarded-For"
    },
    "Cleanup": {
      "IntervalSeconds": 60,
      "BucketIdleTimeoutSeconds": 900,
      "MaxBucketsPerScan": 10000
    },
    "RejectionResponse": {
      "ContentType": "application/json",
      "ErrorCode": "rate_limit_exceeded",
      "Message": "Too many requests. Please retry later."
    },
    "Policies": {
      "Default": {
        "Capacity": 100,
        "RefillTokens": 10,
        "RefillPeriodSeconds": 1,
        "RequestCost": 1
      },
      "Strict": {
        "Capacity": 20,
        "RefillTokens": 2,
        "RefillPeriodSeconds": 1,
        "RequestCost": 1
      }
    },
    "Observability": {
    "Enabled": true,
    "MetricsExporter": "Prometheus"
    },
    "Routes": {
      "sample-api": {
        "PolicyName": "Default"
      }
    }
  },

  "Redis": {
    "ConnectionString": "..."
  },

  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "sample-api": {
        "ClusterId": "sample-backend",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "sample-backend": {
        "Destinations": {
          "sample-backend-primary": {
            "Address": "http://localhost:5255"
          }
        }
      }
    }
  }
}